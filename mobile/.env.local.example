# Buildo Mobile — Local environment example
# Copy to mobile/.env.local and fill in real values from EAS Secrets.
# Never commit .env.local — only this .example file.

# Firebase
EXPO_PUBLIC_FIREBASE_API_KEY=your-api-key-here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:abcdef123456

# Buildo backend
EXPO_PUBLIC_API_URL=https://buildo.app

# Sentry — runtime DSN (the @sentry/react-native/app-plugin in app.json is a
# build-time plugin for native crash source maps; this env var is required for
# JS exception capture at runtime). Leave unset for local dev; set via EAS
# Secrets in production.
EXPO_PUBLIC_SENTRY_DSN=

# PostHog — product telemetry per Spec 90 §11. Leave unset for local dev;
# the analytics module no-ops when the API key is absent. Set via EAS
# Secrets in production.
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Google OAuth (from Google Cloud Console — Credentials)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=000000000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=000000000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=000000000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
