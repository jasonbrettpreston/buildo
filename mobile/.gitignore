# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# Firebase native config — downloaded from Firebase Console; never committed.
# EAS handles them via file secrets (eas secret:create --type file).
google-services.json
GoogleService-Info.plist

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android
