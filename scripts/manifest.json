{
  "version": 1,
  "description": "Single source of truth for pipeline metadata (§9.6)",

  "scripts": {
    "permits":              { "file": "scripts/load-permits.js",          "supports_full": false, "supports_dry_run": false, "telemetry_tables": ["permits"], "telemetry_null_cols": { "permits": ["issued_date", "description", "builder_name", "est_const_cost"] } },
    "close_stale_permits":  { "file": "scripts/close-stale-permits.js",  "supports_full": false, "supports_dry_run": false, "telemetry_tables": ["permits"] },
    "classify_permit_phase":{ "file": "scripts/classify-permit-phase.js","supports_full": false, "supports_dry_run": false, "telemetry_tables": ["permits"] },
    "coa":                  { "file": "scripts/load-coa.js",              "supports_full": true,  "supports_dry_run": false, "telemetry_tables": ["coa_applications"], "telemetry_null_cols": { "coa_applications": ["address", "ward"] } },
    "builders":             { "file": "scripts/extract-builders.js",      "supports_full": false, "supports_dry_run": false, "telemetry_tables": ["entities"], "telemetry_null_cols": { "entities": ["primary_phone", "primary_email", "website"] } },
    "address_points":       { "file": "scripts/load-address-points.js",   "supports_full": false, "supports_dry_run": false, "telemetry_tables": ["address_points"] },
    "parcels":              { "file": "scripts/load-parcels.js",          "supports_full": false, "supports_dry_run": false, "telemetry_tables": ["parcels"], "telemetry_null_cols": { "parcels": ["centroid_lat", "centroid_lng"] } },
    "massing":              { "file": "scripts/load-massing.js",          "supports_full": false, "supports_dry_run": false, "telemetry_tables": ["building_footprints"], "telemetry_null_cols": { "building_footprints": ["centroid_lat", "centroid_lng"] } },
    "neighbourhoods":       { "file": "scripts/load-neighbourhoods.js",   "supports_full": false, "supports_dry_run": false, "telemetry_tables": ["neighbourhoods"], "telemetry_null_cols": { "neighbourhoods": ["geometry"] } },
    "geocode_permits":      { "file": "scripts/geocode-permits.js",       "supports_full": true,  "supports_dry_run": false, "telemetry_tables": ["permits"], "telemetry_null_cols": { "permits": ["latitude", "longitude"] } },
    "link_parcels":         { "file": "scripts/link-parcels.js",          "supports_full": true,  "supports_dry_run": false, "telemetry_tables": ["permit_parcels", "permits"], "telemetry_null_cols": { "permits": ["latitude", "longitude"] } },
    "link_neighbourhoods":  { "file": "scripts/link-neighbourhoods.js",   "supports_full": true,  "supports_dry_run": false, "telemetry_tables": ["permits"], "telemetry_null_cols": { "permits": ["neighbourhood_id"] } },
    "link_massing":         { "file": "scripts/link-massing.js",          "supports_full": true,  "supports_dry_run": false, "chain_args": { "sources": ["--full"] }, "telemetry_tables": ["parcel_buildings"] },
    "link_coa":             { "file": "scripts/link-coa.js",              "supports_full": true,  "supports_dry_run": false, "telemetry_tables": ["coa_applications"], "telemetry_null_cols": { "coa_applications": ["linked_permit_num"] } },
    "enrich_wsib_builders": { "file": "scripts/enrich-web-search.js",     "supports_full": false, "supports_dry_run": false, "env": { "ENRICH_WSIB_ONLY": "1" }, "telemetry_tables": ["entities"], "telemetry_null_cols": { "entities": ["phone", "email", "website"] } },
    "enrich_named_builders":{ "file": "scripts/enrich-web-search.js",     "supports_full": false, "supports_dry_run": false, "env": { "ENRICH_UNMATCHED_ONLY": "1" }, "telemetry_tables": ["entities"], "telemetry_null_cols": { "entities": ["phone", "email", "website"] } },
    "load_wsib":            { "file": "scripts/load-wsib.js",             "supports_full": false, "supports_dry_run": false, "telemetry_tables": ["wsib_registry"], "telemetry_null_cols": { "wsib_registry": ["trade_name", "mailing_address"] } },
    "link_wsib":            { "file": "scripts/link-wsib.js",             "supports_full": true,  "supports_dry_run": false, "telemetry_tables": ["entities"] },
    "enrich_wsib_registry": { "file": "scripts/enrich-wsib.js",          "supports_full": false, "supports_dry_run": false, "env": { "ENRICH_LIMIT": "44000" }, "telemetry_tables": ["wsib_registry"], "telemetry_null_cols": { "wsib_registry": ["primary_phone", "primary_email", "website"] } },
    "classify_scope":       { "file": "scripts/classify-scope.js",        "supports_full": true,  "supports_dry_run": false, "telemetry_tables": ["permits"], "telemetry_null_cols": { "permits": ["scope_classified_at"] } },
    "classify_permits":     { "file": "scripts/classify-permits.js",      "supports_full": true,  "supports_dry_run": false, "telemetry_tables": ["permit_trades", "permits"], "telemetry_null_cols": { "permits": ["trade_classified_at"] } },
    "compute_cost_estimates":       { "file": "scripts/compute-cost-estimates.js",       "supports_full": false, "supports_dry_run": false, "telemetry_tables": ["cost_estimates"], "telemetry_null_cols": { "cost_estimates": ["estimated_cost"] } },
    "compute_timing_calibration":   { "file": "scripts/compute-timing-calibration.js",   "supports_full": false, "supports_dry_run": false, "telemetry_tables": ["timing_calibration"] },
    "compute_timing_calibration_v2": { "file": "scripts/compute-timing-calibration-v2.js", "supports_full": false, "supports_dry_run": false, "telemetry_tables": ["phase_calibration"] },
    "compute_trade_forecasts": { "file": "scripts/compute-trade-forecasts.js", "supports_full": false, "supports_dry_run": false, "telemetry_tables": ["trade_forecasts"] },
    "compute_opportunity_scores": { "file": "scripts/compute-opportunity-scores.js", "supports_full": false, "supports_dry_run": false, "telemetry_tables": ["trade_forecasts"] },
    "update_tracked_projects": { "file": "scripts/update-tracked-projects.js", "supports_full": false, "supports_dry_run": false, "telemetry_tables": ["tracked_projects"] },
    "compute_centroids":    { "file": "scripts/compute-centroids.js",     "supports_full": false, "supports_dry_run": false, "telemetry_tables": ["parcels"], "telemetry_null_cols": { "parcels": ["centroid_lat", "centroid_lng"] } },
    "link_similar":         { "file": "scripts/link-similar.js",          "supports_full": false, "supports_dry_run": false, "telemetry_tables": ["permits"] },
    "create_pre_permits":   { "file": "scripts/create-pre-permits.js",    "supports_full": false, "supports_dry_run": false },
    "refresh_snapshot":     { "file": "scripts/refresh-snapshot.js",      "supports_full": false, "supports_dry_run": false, "telemetry_tables": ["data_quality_snapshots"] },
    "assert_schema":        { "file": "scripts/quality/assert-schema.js", "supports_full": false, "supports_dry_run": false },
    "assert_data_bounds":   { "file": "scripts/quality/assert-data-bounds.js", "supports_full": false, "supports_dry_run": false },
    "assert_engine_health": { "file": "scripts/quality/assert-engine-health.js", "supports_full": false, "supports_dry_run": false, "telemetry_tables": ["engine_health_snapshots"] },
    "assert_network_health": { "file": "scripts/quality/assert-network-health.js", "supports_full": false, "supports_dry_run": false },
    "assert_staleness": { "file": "scripts/quality/assert-staleness.js", "supports_full": false, "supports_dry_run": false },
    "assert_pre_permit_aging": { "file": "scripts/quality/assert-pre-permit-aging.js", "supports_full": false, "supports_dry_run": false },
    "assert_coa_freshness": { "file": "scripts/quality/assert-coa-freshness.js", "supports_full": false, "supports_dry_run": false },
    "inspections":          { "file": "scripts/aic-orchestrator.py", "supports_full": false, "supports_dry_run": false, "telemetry_tables": ["permit_inspections", "permits", "scraper_queue"] },
    "inspections_legacy":   { "file": "scripts/poc-aic-scraper-v2.js", "supports_full": false, "supports_dry_run": false, "telemetry_tables": ["permit_inspections", "permits"], "deprecated": true },
    "classify_inspection_status": { "file": "scripts/classify-inspection-status.js", "supports_full": false, "supports_dry_run": false, "telemetry_tables": ["permits"] },
    "purge_lead_views":     { "file": "scripts/purge-lead-views.js",    "supports_full": false, "supports_dry_run": true, "telemetry_tables": ["lead_views"] },
    "classify_lifecycle_phase": { "file": "scripts/classify-lifecycle-phase.js", "supports_full": false, "supports_dry_run": false, "telemetry_tables": ["permits", "coa_applications"] },
    "coa_documents":        { "file": null, "supports_full": false, "supports_dry_run": false, "coming_soon": true }
  },

  "chains": {
    "permits": [
      "assert_schema", "permits", "close_stale_permits", "classify_permit_phase", "classify_scope",
      "builders", "link_wsib", "geocode_permits", "link_parcels",
      "link_neighbourhoods", "link_massing", "link_similar", "classify_permits",
      "compute_cost_estimates", "compute_timing_calibration",
      "link_coa", "create_pre_permits", "refresh_snapshot", "assert_data_bounds", "assert_engine_health",
      "classify_lifecycle_phase"
    ],
    "coa": [
      "assert_schema", "coa", "assert_coa_freshness", "link_coa", "create_pre_permits",
      "assert_pre_permit_aging", "refresh_snapshot", "assert_data_bounds", "assert_engine_health",
      "classify_lifecycle_phase"
    ],
    "sources": [
      "assert_schema", "address_points", "geocode_permits", "parcels",
      "compute_centroids", "link_parcels", "massing", "link_massing",
      "neighbourhoods", "link_neighbourhoods", "load_wsib", "link_wsib",
      "refresh_snapshot", "assert_data_bounds", "assert_engine_health"
    ],
    "entities": [
      "enrich_wsib_builders", "enrich_named_builders"
    ],
    "wsib": [
      "enrich_wsib_registry"
    ],
    "deep_scrapes": [
      "inspections", "classify_inspection_status", "assert_network_health",
      "refresh_snapshot", "assert_data_bounds", "assert_engine_health", "assert_staleness"
    ]
  },

  "chain_gates": {
    "permits": "permits",
    "coa": "coa"
  }
}
