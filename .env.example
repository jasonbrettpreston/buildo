# Database (Cloud SQL PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/buildo

# Or individual credentials:
# PG_HOST=localhost
# PG_PORT=5432
# PG_DATABASE=buildo
# PG_USER=postgres
# PG_PASSWORD=

# Google Maps Platform
GOOGLE_MAPS_API_KEY=
# Client-side Google Maps key (for Street View, Maps embeds)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# SendGrid (email notifications)
SENDGRID_API_KEY=

# Dev mode — set to "true" to bypass auth (local development only)
NEXT_PUBLIC_DEV_MODE=true

# Firebase (auth + push)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_KEY=

# Serper.dev (web search for builder enrichment)
SERPER_API_KEY=

# Stripe (payments - Phase 4)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# PostHog telemetry (public by design — project-scoped key)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry error tracking
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# GCS Database Backup (scripts/backup-db.js — spec 112)
# Required in production; leave empty locally to skip backup step.
BACKUP_GCS_BUCKET=
