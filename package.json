{
  "name": "buildo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run lint && npm run test",
    "dead-code": "knip",
    "migrate": "node scripts/migrate.js",
    "db:generate": "drizzle-kit introspect",
    "task": "node scripts/task-init.mjs",
    "system-map": "node scripts/generate-system-map.mjs",
    "safe-start": "node -e \"try{require('child_process').execSync('Stop-Process -Id (Get-NetTCPConnection -LocalPort 3000).OwningProcess -Force', {shell: 'powershell.exe', stdio:'ignore'})}catch{}\" && rm -rf .next && npm run build && npm run dev",
    "seed:trades": "npx tsx scripts/seed-trades.ts",
    "spec:tests": "node scripts/harvest-tests.mjs",
    "db:docs": "node scripts/generate-db-docs.mjs",
    "local-cron": "node scripts/local-cron.js",
    "prepare": "husky",
    "biome:check": "biome check",
    "lighthouse:ci": "lhci autorun",
    "sql:lint": "sqlfluff lint --dialect postgres migrations/",
    "ast-grep:leads": "bash scripts/hooks/ast-grep-leads.sh",
    "test:db": "BUILDO_TEST_DB=1 vitest run src/tests/db",
    "test:property": "vitest run src/tests/property",
    "test:mutation": "stryker run",
    "test:mutation:dry": "stryker run --dryRunOnly"
  },
  "lint-staged": {
    "src/features/leads/**/*.{ts,tsx}": [
      "biome check --no-errors-on-unmatched"
    ],
    "src/lib/observability/**/*.{ts,tsx}": [
      "biome check --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@google/genai": "^1.48.0",
    "@heroicons/react": "^2.2.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/nextjs": "^10.47.0",
    "@tanstack/query-async-storage-persister": "^5.96.2",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-query-persist-client": "^5.96.2",
    "@tremor/react": "^3.18.7",
    "@turf/boolean-point-in-polygon": "^7.3.4",
    "@turf/centroid": "^7.3.4",
    "@turf/helpers": "^7.3.4",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "csv-parse": "^6.1.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.45.1",
    "exceljs": "^4.4.0",
    "firebase": "^12.9.0",
    "firebase-admin": "^13.6.1",
    "idb-keyval": "^6.2.2",
    "motion": "^12.38.0",
    "next": "^15.1.0",
    "node-cron": "^4.2.1",
    "openai": "^6.33.0",
    "pg": "^8.13.1",
    "pg-query-stream": "^4.14.0",
    "playwright": "^1.58.2",
    "playwright-extra": "^4.3.6",
    "posthog-js": "^1.365.1",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-infinite-scroll-component": "^7.0.1",
    "shapefile": "^0.6.6",
    "sonner": "^2.0.7",
    "stream-json": "^1.8.0",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@ast-grep/cli": "^0.42.1",
    "@biomejs/biome": "^2.4.10",
    "@eslint/eslintrc": "^3.3.3",
    "@lhci/cli": "^0.15.1",
    "@stryker-mutator/core": "^8.7.1",
    "@stryker-mutator/vitest-runner": "^8.7.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@tanstack/react-query-devtools": "^5.96.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/stream-json": "^1.7.7",
    "@vitejs/plugin-react": "^4.3.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.1.0",
    "fast-check": "^4.6.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.0",
    "knip": "^5.85.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "testcontainers": "^11.14.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
