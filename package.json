{
  "name": "buildo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run lint && npm run test",
    "dead-code": "knip",
    "migrate": "node scripts/migrate.js",
    "db:generate": "drizzle-kit introspect",
    "task": "node scripts/task-init.mjs",
    "system-map": "node scripts/generate-system-map.mjs",
    "safe-start": "node -e \"try{require('child_process').execSync('Stop-Process -Id (Get-NetTCPConnection -LocalPort 3000).OwningProcess -Force', {shell: 'powershell.exe', stdio:'ignore'})}catch{}\" && rm -rf .next && npm run build && npm run dev",
    "seed:trades": "npx tsx scripts/seed-trades.ts",
    "spec:tests": "node scripts/harvest-tests.mjs",
    "db:docs": "node scripts/generate-db-docs.mjs",
    "local-cron": "node scripts/local-cron.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@turf/boolean-point-in-polygon": "^7.3.4",
    "@turf/helpers": "^7.3.4",
    "csv-parse": "^6.1.0",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "exceljs": "^4.4.0",
    "firebase": "^12.9.0",
    "firebase-admin": "^13.6.1",
    "next": "^15.1.0",
    "node-cron": "^4.2.1",
    "pg": "^8.13.1",
    "pg-query-stream": "^4.14.0",
    "playwright": "^1.58.2",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shapefile": "^0.6.6",
    "stream-json": "^1.8.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/stream-json": "^1.7.7",
    "@vitejs/plugin-react": "^4.3.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.1.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.0",
    "knip": "^5.85.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
